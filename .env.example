# NeuralShell Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real secrets to version control

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CONFIG_PATH=./config.yaml

# Redis Configuration (Optional)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=neuralshell:
REDIS_PASSWORD=

# Security
API_KEY_SECRET=your-secret-key-here-change-this
JWT_SECRET=your-jwt-secret-here-change-this
SESSION_SECRET=your-session-secret-here-change-this

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_WINDOW=120
RATE_LIMIT_WINDOW_MS=60000

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
LOG_LEVEL=info

# External API Keys (if using cloud providers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# Database (if applicable)
DATABASE_URL=

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Chaos Engineering (disable in production)
CHAOS_ENABLED=false

# Feature Flags
STREAMING_ENABLED=true
GRAPHQL_ENABLED=true
WEBSOCKET_ENABLED=true
