# NeuralShell Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real secrets to version control

# Server Configuration
NODE_ENV=development
NS_PROFILE=local
PORT=3000
# local: keep loopback; lan/public: set to 0.0.0.0 (and configure allowlists + tokens)
HOST=127.0.0.1
TRUST_PROXY=0
CONFIG_PATH=./config.yaml

# If NS_PROFILE=lan/public and HOST is not loopback, NeuralShell expects TLS by default.
# Set this to 1 only for trusted, isolated LANs (tokens will still be required).
NS_ALLOW_INSECURE_HTTP=0

# TLS (optional; preferred to configure via config.yaml -> server.tls.*)
# NS_TLS=1
# NS_TLS_CERT=./certs/neuralshell.crt
# NS_TLS_KEY=./certs/neuralshell.key
# NS_TLS_PFX=./certs/server/neuralshell.pfx
# NS_TLS_PFX_PASSPHRASE=
# NS_TLS_CA=./certs/ca.crt
# NS_TLS_REQUIRE_CLIENT_CERT=0

# Redis Configuration (Optional)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=neuralshell:
REDIS_PASSWORD=

# Security
API_KEY_SECRET=your-secret-key-here-change-this
JWT_SECRET=your-jwt-secret-here-change-this
SESSION_SECRET=your-session-secret-here-change-this
ADMIN_TOKEN=
PROMPT_TOKEN=

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_WINDOW=120
RATE_LIMIT_WINDOW_MS=60000

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
LOG_LEVEL=info

# External API Keys (if using cloud providers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=
AZURE_OPENAI_API_KEY=

# AWS (Bedrock) Credentials (if using Bedrock)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Database (if applicable)
DATABASE_URL=

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Chaos Engineering (disable in production)
CHAOS_ENABLED=false

# Feature Flags
STREAMING_ENABLED=true
GRAPHQL_ENABLED=true
WEBSOCKET_ENABLED=true


# Sandbox (code execution)
# NS_SANDBOX_BACKEND can be: docker | vm | auto
NS_SANDBOX_BACKEND=docker
# If NS_SANDBOX_BACKEND=auto, allow fallback to vm when Docker is unavailable
NS_SANDBOX_ALLOW_VM_FALLBACK=0
# Override the sandbox image (must exist locally or be pullable by Docker)
NS_SANDBOX_IMAGE=node:20-alpine
# Whether sandbox:prepare is allowed to pull the image if missing
NS_SANDBOX_PREPARE_PULL=1



