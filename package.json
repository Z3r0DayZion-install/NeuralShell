{
  "name": "neuralshell-v5",
  "version": "1.0.7-OMEGA",
  "description": "NeuralShell v5 – modular chat client with model switching and session management",
  "main": "src/main.js",
  "author": "NeuralShell Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0 <21"
  },
  "scripts": {
    "start": "electron .",
    "test": "node tear/smoke-test.js && node tear/ipc-surface-test.js && node tear/renderer-bindings-test.js && node tear/linkage-regression-test.js && node tear/unit-tests.js && node tear/policy-firewall.test.js && node tear/audit-chain.test.js && node tear/security-guards.test.js && node tear/cleanup-guard.test.js && node tear/release-manifest.test.js && node tear/release-checksums.test.js && node tear/ship-entrypoints.test.js && node tear/release-freshness.test.js && node tear/release-status-contract.test.js && node tear/worktree-cleanliness.test.js && node tear/session-manager.test.js && node tear/state-manager.test.js",
    "hooks:install": "node scripts/install-hooks.js",
    "gate:prepush": "node scripts/prepush-gate.js",
    "determinism:test": "node scripts/determinism_test.js",
    "smoke:packaged:strict": "node tear/smoke-packaged.js --strict-launch --isolated-user-data --timeout-ms=25000",
    "diagnose:packaged": "node tear/diagnose-packaged-launch.js --require-uptime-ms=4500",
    "release:worktree": "node scripts/verify-clean-worktree.js",
    "release:worktree:strict": "node scripts/verify-clean-worktree.js --strict",
    "release:gate": "node tear/release-gate.js",
    "release:gate:strict": "node tear/release-gate.js --strict-packaged",
    "release:manifest": "node scripts/release-manifest.js",
    "release:sign": "node scripts/sign-release.js",
    "release:status": "node tear/release-status.js",
    "release:checksums": "node scripts/release-checksums.js",
    "release:notes": "node scripts/release-notes.js",
    "release:verify:fresh": "node tear/verify-release-freshness.js",
    "release:verify:fresh:strict": "node tear/verify-release-freshness.js --strict-installer",
    "benchmark:autonomy": "node tear/benchmark-autonomy.js",
    "benchmark:regression": "node tear/regression-eval.js",
    "redteam:nightly": "node tear/redteam-nightly.js",
    "kpi:operator": "node tear/operator-kpi.js",
    "slo:gate": "node tear/slo-gate.js",
    "diagnose:crash": "node tear/classify-crash.js",
    "replay:autonomy": "node tear/replay-autonomy.js",
    "sbom:generate": "node scripts/generate-sbom.js",
    "attest:release": "node scripts/generate-attestation.js",
    "ship": "node scripts/ship.js",
    "ship:strict": "node scripts/ship-strict.js",
    "verify:strict": "npm test && npm run benchmark:autonomy && npm run benchmark:regression && npm run redteam:nightly && npm run release:gate:strict && npm run release:manifest && npm run release:status && npm run release:checksums && npm run release:verify:fresh:strict && npm run kpi:operator && npm run slo:gate",
    "verify:all": "npm test && npm run build",
    "icons:generate": "node tear/generate-icons.js",
    "build": "electron-builder",
    "dist": "electron-builder --publish never",
    "lint": "eslint src/ scripts/ tear/ tests/ --max-warnings=0",
    "lint:fix": "eslint src/ scripts/ tear/ tests/ --fix"
  },
  "dependencies": {
    "@neural/omega-core": "file:vendor/omega-core",
    "dayjs": "^1.11.9",
    "electron-updater": "^6.7.3",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@eslint/js": "^9.39.3",
    "ajv": "^6.14.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.3",
    "eslint-plugin-security": "^4.0.0",
    "icon-gen": "^5.0.0",
    "pngjs": "^7.0.0"
  },
  "build": {
    "productName": "NeuralShell",
    "appId": "com.neuralshell.app",
    "files": [
      "**/*",
      "!dist/**",
      "!dist_fresh/**",
      "!release/**",
      "!tmp/**",
      "!**/*.log",
      "!bin/**"
    ],
    "asarUnpack": [
      "**/bin/*.exe"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "neural-linkd.exe"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.neuralshell.app/desktop/"
      }
    ]
  }
}
