{
  "name": "neuralshell",
  "version": "1.0.0",
  "description": "Verified Autonomous AI Runtime",
  "main": "production-server.js",
  "type": "module",
  "scripts": {
    "test": "npm run proof:all && npm run test:root",
    "rust:release": "node scripts/run-cargo.mjs run -p neuralshell-release -- bundle",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "proof:spawn": "node scripts/run_server_once.cjs",
    "rust:core:cli": "node scripts/run-cargo.mjs run -p neuralshell-core-cli --",
    "ship:bundle": "node scripts/release-bundle.mjs",
    "proof:all": "node scripts/proof_all.cjs",
    "security:audit": "npm audit --audit-level=moderate",
    "test:desktop": "npm --prefix NeuralShell_Desktop run test:serial",
    "ast-gate": "node scripts/ast-security-gate.cjs",
    "autonomy:demo": "node scripts/demo-autonomy.mjs",
    "proof:exe": "node scripts/exe_proof.cjs",
    "proof": "node proof/proof.js",
    "test:root": "node test/router.test.js",
    "verify:all": "node scripts/verify_runner.cjs",
    "test:chaos": "node test/router.chaos.test.js",
    "postinstall": "node scripts/verify-installation.js",
    "proof:runtime": "node scripts/runtime_proof.cjs",
    "rust:core:test": "node scripts/run-cargo.mjs test -p neuralshell-core",
    "support:bundle": "node scripts/support-bundle.mjs",
    "security:check": "npm run security:audit && npm run lint",
    "verify": "npm run lint && npm run autonomy:verify && npm run test:all",
    "test:contract": "node test/router.contract.test.js",
    "proof:tear": "node scripts/tear_proof.cjs",
    "proof:all:chain": "npm run proof:spawn && npm run proof:runtime",
    "release:manifest": "node scripts/release_manifest.cjs",
    "proof:crash": "node scripts/crash_recovery_proof.cjs",
    "start": "node production-server.js",
    "dev": "node production-server.js --dev",
    "lint:fix": "eslint production-server.js scripts/verify-autonomy-wiring.js src/swarm/messageBus.js src/swarm/federationNode.js --ext .js --fix",
    "autonomy:verify": "node scripts/verify-autonomy-wiring.js",
    "spawn:sanity": "node scripts/spawn_sanity.cjs",
    "proof:bundle": "node scripts/proof_bundle.cjs",
    "clean:artifacts": "node scripts/cleanup-artifacts.js",
    "release:gate": "call scripts\\release_gate.cmd",
    "test:all": "npm run test:contract && npm run test:chaos && npm run test:root",
    "test:integration": "node test/router.integration.test.js",
    "lint": "eslint production-server.js scripts/verify-autonomy-wiring.js src/swarm/messageBus.js src/swarm/federationNode.js --ext .js --max-warnings 0",
    "proof:reset": "node scripts/proof-reset.mjs",
    "llm:preflight": "node scripts/llm-connection-test.mjs --dry-run",
    "llm:test": "node scripts/llm-connection-test.mjs --live",
    "test:sandbox": "node test/sandbox.test.js",
    "sandbox:smoke": "npm run test:sandbox",
    "sandbox:prepare": "node scripts/sandbox-prepare.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^8.0.4",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@fastify/websocket": "^11.2.0",
    "@graphql-tools/schema": "^10.0.31",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^1.25.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.1",
    "@opentelemetry/resources": "^1.25.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@opentelemetry/sdk-trace-node": "^1.25.1",
    "@opentelemetry/semantic-conventions": "^1.25.1",
    "@xenova/transformers": "^2.17.2",
    "dockerode": "^4.0.2",
    "fastify": "^5.7.4",
    "get-port": "^7.0.0",
    "graphql": "^16.12.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^6.0.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "node-fetch": "^3.3.2",
    "pg": "^8.12.0",
    "redis": "^5.11.0",
    "tar-fs": "^3.0.5",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@types/node": "^25.3.0",
    "eslint": "^8.57.0",
    "glob": "^13.0.6",
    "jest": "^29.7.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
