{
  "name": "neuralshell-v5",
  "version": "1.2.0-OMEGA",
  "description": "NeuralShell v5 – modular chat client with model switching and session management",
  "main": "src/main.js",
  "author": "NeuralShell Team",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "start": "electron .",
    "test": "node tear/smoke-test.js && node tear/ipc-surface-test.js && node tear/renderer-bindings-test.js && node tear/linkage-regression-test.js && node tear/unit-tests.js && node tear/policy-firewall.test.js && node tear/audit-chain.test.js && node tear/security-guards.test.js && node tear/security-abuse.test.js && node tear/branch-protection-policy.test.js && node tear/cleanup-guard.test.js && node tear/release-manifest.test.js && node tear/release-checksums.test.js && node tear/release-upgrade-validation.test.js && node tear/release-workflows-contract.test.js && node tear/ship-entrypoints.test.js && node tear/performance-gate-contract.test.js && node tear/release-freshness.test.js && node tear/release-status-contract.test.js && node tear/worktree-cleanliness.test.js && node tear/session-manager.test.js && node tear/state-manager.test.js",
    "hooks:install": "node scripts/install-hooks.js",
    "gate:prepush": "node scripts/prepush-gate.js",
    "determinism:test": "node scripts/determinism_test.js",
    "smoke:packaged:strict": "node tear/smoke-packaged.js --strict-launch --isolated-user-data --timeout-ms=25000",
    "diagnose:packaged": "node tear/diagnose-packaged-launch.js --require-uptime-ms=4500",
    "smoke:installer": "node tear/smoke-installer.js --strict-install --timeout-ms=45000",
    "release:worktree": "node scripts/verify-clean-worktree.js",
    "release:worktree:strict": "node scripts/verify-clean-worktree.js --strict",
    "release:gate": "node tear/release-gate.js",
    "release:gate:strict": "node tear/release-gate.js --strict-packaged",
    "release:manifest": "node scripts/release-manifest.js",
    "release:sign": "node scripts/sign-release.js",
    "release:status": "node tear/release-status.js",
    "release:upgrade:validate": "node scripts/release-upgrade-validation.js --strict",
    "release:checksums": "node scripts/release-checksums.js",
    "release:verify:signature": "node scripts/verify-release-signature.js",
    "release:notes": "node scripts/release-notes.js",
    "release:verify:fresh": "node tear/verify-release-freshness.js",
    "release:verify:fresh:strict": "node tear/verify-release-freshness.js --strict-installer",
    "canary:gate": "node scripts/canary-gate.js --cycles=3 --min-uptime-ms=750",
    "canary:24h": "node scripts/canary-gate.js --duration-hours=24 --cycles=1 --delay-ms=300000 --min-uptime-ms=750",
    "benchmark:autonomy": "node tear/benchmark-autonomy.js",
    "benchmark:regression": "node tear/regression-eval.js",
    "redteam:nightly": "node tear/redteam-nightly.js",
    "kpi:operator": "node tear/operator-kpi.js",
    "slo:gate": "node tear/slo-gate.js",
    "diagnose:crash": "node tear/classify-crash.js",
    "replay:autonomy": "node tear/replay-autonomy.js",
    "sbom:generate": "node scripts/generate-sbom.js",
    "attest:release": "node scripts/generate-attestation.js",
    "security:pass": "node scripts/security-pass.js",
    "security:pass:local": "node scripts/security-pass.js --skip-audit",
    "governance:branch:verify": "node scripts/verify-branch-protection.js",
    "governance:branch:enforce": "node scripts/enforce-branch-protection.js",
    "governance:branch:enforce:dry": "node scripts/enforce-branch-protection.js --dry-run",
    "governance:merge:controlled": "node scripts/controlled-merge-window.js",
    "governance:merge:controlled:dry": "node scripts/controlled-merge-window.js --dry-run",
    "perf:gate": "node scripts/performance-gate.js",
    "ship": "node scripts/ship.js",
    "ship:strict": "node scripts/ship-strict.js",
    "verify:ship": "npm run icons:generate && npm run release:worktree:strict && npm run lint && npm run test:flaky && npm run coverage:check && npm run security:pass:local && npm run build && npm run release:gate:strict && npm run canary:gate && npm run diagnose:packaged && npm run release:manifest && npm run release:sign && npm run release:verify:signature && npm run release:status && npm run release:upgrade:validate && npm run release:checksums && npm run release:verify:fresh:strict && npm run kpi:operator && npm run slo:gate && npm run perf:gate",
    "verify:strict": "npm run verify:ship && npm run benchmark:regression && npm run redteam:nightly && npm run replay:autonomy",
    "verify:all": "npm run lint && npm run test:flaky && npm run coverage:check && npm run build",
    "maintain:verify": "node scripts/maintenance-clean-verify.js",
    "maintain:clean": "node scripts/maintenance-clean-verify.js --skip-verify",
    "icons:generate": "node tear/generate-icons.js",
    "build": "electron-builder",
    "dist": "electron-builder --publish never",
    "test:flaky": "node scripts/flaky-test-gate.js npm test",
    "test:e2e": "playwright test -c playwright.e2e.config.js",
    "coverage:test": "c8 --clean --reporter=text-summary --reporter=json-summary npm test",
    "coverage:check": "npm run coverage:test && node scripts/check-coverage-thresholds.js",
    "lint": "eslint src/ scripts/ tear/ tests/ --max-warnings=0",
    "lint:fix": "eslint src/ scripts/ tear/ tests/ --fix"
  },
  "dependencies": {
    "@neural/omega-core": "file:vendor/omega-core",
    "dayjs": "^1.11.9",
    "electron-updater": "^6.8.3",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "ajv": "^6.14.0",
    "c8": "^11.0.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "eslint-plugin-security": "^4.0.0",
    "icon-gen": "^5.0.0",
    "pngjs": "^7.0.0"
  },
  "build": {
    "productName": "NeuralShell",
    "appId": "com.neuralshell.app",
    "files": [
      "**/*",
      "!dist/**",
      "!dist_fresh/**",
      "!release/**",
      "!tmp/**",
      "!**/*.zip",
      "!**/*.log",
      "!bin/**"
    ],
    "asarUnpack": [
      "**/bin/*.exe"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "neural-linkd.exe"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.neuralshell.app/desktop/"
      }
    ]
  }
}
