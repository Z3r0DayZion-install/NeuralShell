{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:4173/pwa/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "emulatedFormFactor": "mobile",
        "onlyCategories": [
          "performance",
          "best-practices",
          "pwa"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:pwa": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    }
  }
}
